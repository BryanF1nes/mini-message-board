<%- include("../partials/errors.ejs") %>

<form
  method="POST"
  action="/admin/changelog/create"
  class="flex flex-col gap-4"
>

  <!-- Description -->
  <div class="flex flex-col gap-2">
    <label
      for="description"
      class="text-sm font-medium text-slate-700"
    >
      Description
    </label>

    <input
      type="text"
      id="description"
      name="description"
      placeholder="Version 1.0.1 - HTML Support"
      required
      class="rounded-2xl border border-slate-200 px-4 py-3 text-slate-900 placeholder-slate-400 focus:border-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-100"
    >
  </div>

  <!-- Changes -->
  <div class="flex flex-col gap-2">
    <label
      for="changes"
      class="text-sm font-medium text-slate-700"
    >
      Enter Changes
    </label>

    <textarea
      id="changes"
      name="changes"
      rows="5"
      placeholder="Enter each change on a new line"
      required
      class="min-h-[120px] resize-y rounded-[12px] border border-slate-200 px-4 py-3 text-slate-900 placeholder-slate-400 focus:border-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-100"
    ></textarea>
  </div>

  <button
    type="submit"
    class="self-start rounded-2xl bg-blue-600 px-5 py-3 font-semibold text-white transition hover:bg-blue-700 active:translate-y-px"
  >
    Post Changelog
  </button>

</form>
