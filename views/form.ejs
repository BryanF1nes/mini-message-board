<%- include("partials/errors.ejs") %>

<form method="POST" action="/messages/create" class="flex flex-col gap-4">

  <div class="flex flex-col gap-2">
    <label for="message" class="font-medium text-slate-700">
      Message
    </label>

    <textarea
      id="message"
      name="message"
      rows="5"
      placeholder="What's on your mind?"
      required
      class="min-h-[120px] max-h-[250px] resize-y rounded-2xl border border-slate-200 bg-white px-4 py-3 text-slate-900 placeholder-slate-400 focus:border-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-100"
    ></textarea>

    <div class="flex items-center gap-3 mb-2">
      <input
        type="checkbox"
        id="locked"
        name="locked"
        value="true"
        checked
        class="h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-2 focus:ring-blue-100"
      >

      <label
        for="locked"
        class="text-sm font-medium text-slate-700"
      >
        Can users reply to this message?
      </label>
    </div>

  <button
    type="submit"
    class="self-start rounded-[12px] bg-blue-600 px-5 py-3 font-semibold text-white transition hover:bg-blue-700 active:translate-y-px"
  >
    Post Message
  </button>

</form>
