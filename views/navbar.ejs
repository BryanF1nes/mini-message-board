<nav class="border-b border-slate-200 bg-white px-4 shadow-sm">
  <div class="mx-auto max-w-7xl">

    <div class="flex min-h-16 items-center justify-between">

      <div class="flex items-center gap-6">
        <h4 class="text-xl font-bold tracking-tight text-slate-900">
          Mini Message Board
        </h4>

        <!-- Desktop Navigation -->
        <ul class="hidden md:flex items-center gap-2">
          <% for (let i = 0; i < links.length; i++) { %>
            <li class="relative">
              <a
                href="<%= links[i].href %>"
                class="group flex items-center rounded-[10px] px-4 py-3 text-[0.95rem] font-medium text-slate-700 transition-all duration-200 hover:bg-slate-100 hover:text-blue-600"
              >
                <span><%= links[i].text %></span>

                <span
                  class="absolute bottom-1 left-4 right-4 h-0.5 origin-center scale-x-0 bg-blue-600 transition-transform duration-200 group-hover:scale-x-100"
                ></span>
              </a>
            </li>
          <% } %>
        </ul>
      </div>

      <!-- Desktop Search -->
      <div class="hidden md:block">
        <%- include('search') %>
      </div>

      <!-- Mobile Hamburger -->
      <button
        id="mobile-menu-btn"
        class="rounded-md p-2 text-slate-700 hover:bg-slate-100 md:hidden"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"
          />
        </svg>
      </button>

    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden border-t border-slate-200 py-3 md:hidden">
      <ul class="space-y-1">
        <% for (let i = 0; i < links.length; i++) { %>
          <li>
            <a
              href="<%= links[i].href %>"
              class="block rounded-md px-4 py-3 text-slate-700 hover:bg-slate-100"
            >
              <%= links[i].text %>
            </a>
          </li>
        <% } %>
      </ul>

      <div class="mt-4">
        <%- include('search') %>
      </div>
    </div>

  </div>
</nav>
