<main class="mx-auto max-w-3xl px-6 py-10">
  <div
    id="<%= message.id %>"
    class="rounded-2xl border border-slate-200 bg-white p-6 shadow-md"
  >
    <h4 class="mb-3 text-xl font-semibold text-slate-900">
      <%= message.username %>
    </h4>

    <p class="mb-6 whitespace-pre-wrap break-words text-slate-700"><%= message.body %></p>

    <div class="flex items-center justify-between text-sm text-slate-500">
      <p
        class="message-date"
        data-date="<%= message.date_added.toISOString() %>"
      >
        Loading...
      </p>

      <% if (currentUser && (currentUser.id === message.user_id || currentUser.role === 'admin')) { %>
        <a
          href="/messages/<%= message.id %>/edit"
          class="font-medium text-blue-600 hover:text-blue-700"
        >
          Edit
        </a>
      <% } %>
    </div>
  </div>

  <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-md">
    <h3 class="mb-4 text-lg font-semibold text-slate-900">
      Replies (<%= replies.length %>)
    </h3>

    <% if (replies.length > 0) { %>
      <div class="space-y-4">
        <% replies.forEach((reply) => { %>
          <div
            class="rounded-xl border border-slate-200 bg-slate-50 p-4"
            id="reply-<%= reply.id %>"
          >
            <div class="mb-2 flex items-center justify-between">
              <h4 class="font-medium text-slate-900">
                <%= reply.username %>
              </h4>

              <span
                class="message-date text-sm text-slate-500"
                data-date="<%= reply.date_added.toISOString() %>"
              >
                Loading...
              </span>
            </div>

            <p class="whitespace-pre-wrap break-words text-slate-700">
              <%= reply.body %>
            </p>

            <% if (currentUser && (currentUser.id === reply.user_id || currentUser.role === 'admin')) { %>
              <div class="mt-3">
                <a
                  href="/replies/<%= reply.id %>/edit"
                  class="text-sm font-medium text-blue-600 hover:text-blue-700"
                >
                  Edit
                </a>
              </div>
            <% } %>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <p class="text-slate-500">
        No replies yet. Be the first to reply.
      </p>
    <% } %>
  </div>

  <% if (currentUser) { %>
    <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-md">
      <h3 class="mb-4 text-lg font-semibold text-slate-900">
        Post a Reply
      </h3>

      <form
        action="/messages/<%= message.id %>/replies/create"
        method="POST"
        class="flex flex-col gap-4"
      >
        <textarea
          name="body"
          rows="4"
          placeholder="Write a reply..."
          required
          class="min-h-[100px] resize-y rounded-[12px] border border-slate-200 px-4 py-3 text-slate-900 placeholder-slate-400 focus:border-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-100"
        ></textarea>

        <button
          type="submit"
          class="self-start rounded-[12px] bg-blue-600 px-5 py-3 font-semibold text-white transition hover:bg-blue-700 active:translate-y-px"
        >
          Post Reply
        </button>
      </form>
    </div>
  <% } %>
</main>
