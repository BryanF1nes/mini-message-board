<main class="mx-auto max-w-5xl px-4 py-10">
  <div class="rounded-[12px] border border-slate-200 bg-white p-6 shadow-md">
    <h2 class="mb-6 text-2xl font-bold text-slate-900">Profile</h2>

    <div class="grid gap-6 sm:grid-cols-2">
      <div>
        <p class="mb-1 text-sm font-medium text-slate-500">First Name</p>
        <p class="text-slate-900"><%= data.first_name || "Not provided" %></p>
      </div>

      <div>
        <p class="mb-1 text-sm font-medium text-slate-500">Last Name</p>
        <p class="text-slate-900"><%= data.last_name || "Not provided" %></p>
      </div>

      <div class="sm:col-span-2">
        <p class="mb-1 text-sm font-medium text-slate-500">Email</p>
        <p class="text-slate-900"><%= data.email || "Not provided" %></p>
      </div>

      <div class="sm:col-span-2">
        <p class="mb-1 text-sm font-medium text-slate-500">Bio</p>
        <div class="rounded-lg bg-slate-50 p-4 text-slate-700">
          <%= data.bio || "No bio has been added yet." %>
        </div>
      </div>
    </div>

    <div class="mt-8 border-t border-slate-200 pt-6">
      <a href="/profile/<%= data.user_id %>/edit" class="inline-flex rounded-[12px] bg-blue-600 px-5 py-3 font-semibold text-white transition hover:bg-blue-700 active:translate-y-px">
        Edit Profile
      </a>
    </div>
  </div>

  <div class="mt-6 rounded-[12px] border border-slate-200 bg-white p-6 shadow-md">
    <h3 class="mb-2 text-xl font-bold text-slate-900">Messages</h3>
    <p class="text-slate-500">User messages will appear here.</p>
  </div>
</main>
