<main class="mx-auto max-w-5xl px-4 py-10">
  <div class="rounded-[12px] border border-slate-200 bg-white p-6 shadow-md">
    <h2 class="mb-6 text-2xl font-bold text-slate-900">Edit Profile</h2>

    <form action="/profile/<%= data.user_id %>/edit" method="POST" class="flex flex-col gap-4">
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="flex flex-col gap-2">
          <label for="first_name" class="text-sm font-medium text-slate-700">
            First Name
          </label>
          <input
            type="text"
            id="first_name"
            name="first_name"
            value="<%= data.first_name || '' %>"
            class="rounded-[12px] border border-slate-200 px-4 py-3 text-slate-900 placeholder-slate-400 focus:border-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-100"
          >
        </div>

        <div class="flex flex-col gap-2">
          <label for="last_name" class="text-sm font-medium text-slate-700">
            Last Name
          </label>
          <input
            type="text"
            id="last_name"
            name="last_name"
            value="<%= data.last_name || '' %>"
            class="rounded-[12px] border border-slate-200 px-4 py-3 text-slate-900 placeholder-slate-400 focus:border-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-100"
          >
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <label for="email" class="text-sm font-medium text-slate-700">
          Email
        </label>
        <input
          type="email"
          id="email"
          name="email"
          value="<%= data.email || '' %>"
          class="rounded-[12px] border border-slate-200 px-4 py-3 text-slate-900 placeholder-slate-400 focus:border-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-100"
        >
      </div>

      <div class="flex flex-col gap-2">
        <label for="bio" class="text-sm font-medium text-slate-700">
          Bio
        </label>
        <textarea
          id="bio"
          name="bio"
          rows="6"
          class="min-h-[150px] resize-y rounded-[12px] border border-slate-200 px-4 py-3 text-slate-900 placeholder-slate-400 focus:border-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-100"
        ><%= data.bio || '' %></textarea>
      </div>

      <div class="mt-2 flex gap-3">
        <button
          type="submit"
          class="rounded-[12px] bg-blue-600 px-5 py-3 font-semibold text-white transition hover:bg-blue-700 active:translate-y-px"
        >
          Save Changes
        </button>

        <a
          href="/profile"
          class="rounded-[12px] border border-slate-200 px-5 py-3 font-semibold text-slate-700 transition hover:bg-slate-50"
        >
          Cancel
        </a>
      </div>
    </form>
  </div>
</main>
