<html>
    <head>
        <link rel="stylesheet" href="/styles.css">
    </head>
    <body>
        <%- include('navbar', { liks: links }); %>
        <div class="container">
            <div class="card">
                <form method="POST" action="/messages/edit/<%= message.id %>">
                  <div>
                    <label for="user">Your Name</label>
                    <input
                      type="text"
                      id="user"
                      name="user"
                      placeholder="Enter your name"
                      value="<%= message.user %>"
                    >
                  </div>

                  <div>
                    <label for="text">Message</label>
                    <textarea
                      id="text"
                      name="text"
                      rows="5"
                      placeholder="What's on your mind?"
                      required
                    ><%= message.text %></textarea>
                  </div>

                  <button type="submit">Edit Message</button>
                </form>
            </div>
        </div>
        <%- include('footer'); %>
    </body>
</html>
