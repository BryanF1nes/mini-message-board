<main class="mx-auto flex max-w-6xl flex-col gap-6 px-6 py-10">
  <!-- Create Message -->
  <% if (currentUser) { %>
    <section class="w-full rounded-[12px] border border-slate-200 bg-white p-6 shadow-md">
      <h3 class="mb-4 text-xl font-bold text-slate-900">
        Create A Message
      </h3>
      <%- include('form') %>
    </section>
  <% } else { %>
    <p class="text-slate-600">
      You need to create an account to create messages.
    </p>
  <% } %>
  <!-- Messages -->
  <section class="w-full rounded-[12px] border border-slate-200 bg-white p-6 shadow-md">
    <h3 class="mb-6 text-xl font-bold text-slate-900">
      Messages
    </h3>
    <% if (messages.length > 0) { %>
      <!-- Grid instead of flex gap-2 -->
      <div class="grid gap-4 grid-cols-1">
        <% messages.forEach((message) => { %>
          <div
            id="<%= message.id %>"
            class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:shadow-md"
          >
            <h4 class="mb-2 font-semibold text-slate-900">
              <%= message.username %>
            </h4>
            <p class="whitespace-pre-wrap wrap-break-word mb-4 text-slate-700"><%= message.body %></p>
            <div class="flex items-center justify-between text-sm text-slate-500">
              <span
                class="message-date"
                data-date="<%= message.date_added.toISOString() %>"
              >
                Loading...
              </span>
             <div class="flex gap-2">
                  <p class="replies">Replies: </p>
                  <a href="/messages/<%= message.id %>" class="font-medium text-blue-600 hover:text-blue-700">View</a>

                    <% if (currentUser && currentUser.role === "admin" || currentUser && currentUser.id === message.user_id) { %>
                        <form action="/messages/<%=message.id %>/delete" method="POST">
                            <button type="submit" class="font-medium text-blue-600 hover:text-blue-700 cursor-pointer">Delete</button>
                        </form>
                    <% } %>
             </div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <p class="text-slate-600">No messages found.</p>
    <% } %>
  </section>
</main>
<script src="/js/replies.js"></script>
