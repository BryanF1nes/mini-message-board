<main class="mx-auto flex max-w-2xl flex-col items-center px-6 py-12">
  <div class="w-full rounded-2xl border border-slate-200 bg-white p-6 shadow-md">

    <h3 class="mb-6 text-xl font-bold text-slate-900">
      <%= title %>
    </h3>

    <form action="/log-in" method="POST" class="flex flex-col gap-4">

      <!-- Username -->
      <div class="flex flex-col gap-2">
        <label for="username" class="text-sm font-medium text-slate-700">
          Username
        </label>

        <input
          type="text"
          id="username"
          name="username"
          placeholder="Username"
          required
          class="rounded-2xl border border-slate-200 px-4 py-3 text-slate-900 placeholder-slate-400 focus:border-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-100"
        >
      </div>

      <!-- Password -->
      <div class="flex flex-col gap-2">
        <label for="password" class="text-sm font-medium text-slate-700">
          Password
        </label>

        <input
          type="password"
          id="password"
          name="password"
          placeholder="Password"
          required
          class="rounded-[12px] border border-slate-200 px-4 py-3 text-slate-900 placeholder-slate-400 focus:border-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-100"
        >
      </div>

      <!-- Button -->
      <button
        type="submit"
        class="mt-2 rounded-[12px] bg-blue-600 px-5 py-3 font-semibold text-white transition hover:bg-blue-700 active:translate-y-px"
      >
        <%= title %>
      </button>

    </form>

  </div>
</main>
